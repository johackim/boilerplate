{{#if isSecondary}}
    {{#foreach navigation }}
    <a href="{{url absolute="true"}}" class="mr-6 text-gray-600 hover:text-gray-900{{#if current}} active{{/if}}">{{label}}</a>
    {{/foreach}}
{{else}}
<div class="hidden lg:block">
    {{#foreach navigation}}
    <a href="{{url absolute="true"}}" class="mr-6 text-gray-600 hover:text-gray-900{{#if current}} active{{/if}}">{{label}}</a>
    {{/foreach}}
</div>
<div class="block lg:hidden">
    <button type="button" class="flex items-center px-3 py-2 border rounded text-gray-900 border-gray-900">
        <svg class="fill-current h-3 w-3" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z" /></svg>
    </button>
</div>
{{/if}}
