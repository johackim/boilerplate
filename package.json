{
    "name": "boilerplate",
    "version": "0.1.0",
    "author": {
        "name": "johackim",
        "email": "contact@johackim.com"
    },
    "scripts": {
        "start": "docker run --rm -e NODE_ENV=development -v $PWD:/var/lib/ghost/content/themes/casper -p 2368:2368 ghost:alpine",
        "dev": "gulp",
        "zip": "gulp zip",
        "test": "gscan ."
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme",
        "tailwindcss"
    ],
    "devDependencies": {
        "autoprefixer": "9.7.3",
        "cssnano": "4.1.10",
        "gscan": "3.3.3",
        "gulp": "4.0.2",
        "gulp-livereload": "4.0.1",
        "gulp-postcss": "8.0.0",
        "gulp-sourcemaps": "2.6.5",
        "gulp-uglify": "3.0.2",
        "gulp-util": "3.0.8",
        "gulp-watch": "5.0.1",
        "gulp-zip": "5.0.0",
        "postcss-color-function": "4.1.0",
        "postcss-custom-properties": "9.1.1",
        "postcss-easy-import": "3.0.0",
        "tailwindcss": "^1.2.0"
    },
    "browserslist": [
        "defaults"
    ],
    "config": {
        "posts_per_page": 15,
        "image_sizes": {
            "xxs": {
                "width": 30
            },
            "xs": {
                "width": 100
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 600
            },
            "l": {
                "width": 1200
            },
            "xl": {
                "width": 2000
            }
        }
    }
}
